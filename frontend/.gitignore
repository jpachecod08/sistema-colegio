# Crear/actualizar .gitignore dentro de la carpeta frontend
echo "# Dependencias
node_modules/
/.pnp
.pnp.js

# Producción
/dist
/build

# Variables de entorno
.env
.env.local
.env.production
.env.development

# Archivos del sistema
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.vscode/
.idea/

# Vite
.vite/
" > .gitignore